@model IEnumerable<Fee>
@{ ViewData["Title"] = "Fees"; }

<h2>Fees</h2>

<a asp-action="Create" class="btn btn-primary mb-3">Add Fee</a>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Amount</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var fee in Model)
        {
            <tr>
                <td>@fee.Name</td>
                <td>$@fee.Amount.ToString("0.00")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@fee.ID" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@fee.ID" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>