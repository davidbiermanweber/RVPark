@model AvailabilitySearchViewModel
@{
    ViewData["Title"] = "Find a Site";
    var isCustomer = User.Identity?.IsAuthenticated == true && User.FindFirst("Role")?.Value == "Customer";
}

<div class="container" style="max-width: 900px;">
    <h2 class="mb-3">🔍 Find an Available Site</h2>

    <div asp-validation-summary="All" class="text-danger"></div>

    <form method="get" asp-action="Search" class="row g-2 mb-4">
        <div class="col-6 col-md-3">
            <label class="form-label">Arrival</label>
            <input type="date" name="start" value="@(Model.Start?.ToString("yyyy-MM-dd"))" class="form-control" required />
        </div>
        <div class="col-6 col-md-3">
            <label class="form-label">Departure</label>
            <input type="date" name="end" value="@(Model.End?.ToString("yyyy-MM-dd"))" class="form-control" required />
        </div>
        <div class="col-8 col-md-3">
            <label class="form-label">Site type</label>
            <select name="categoryId" class="form-select" asp-items="@(ViewBag.Categories as SelectList)">
                <option value="">Any</option>
            </select>
        </div>
        <div class="col-4 col-md-2">
            <label class="form-label">RV ft</label>
            <input type="number" name="rvLength" min="0" value="@(Model.RvLength)" class="form-control" placeholder="Any" />
        </div>
        <div class="col-12 col-md-1 d-grid align-items-end">
            <label class="form-label d-none d-md-block">&nbsp;</label>
            <button type="submit" class="btn btn-primary">Search</button>
        </div>
    </form>

    @if (Model.Searched)
    {
        <h5 class="mb-3">
            @Model.Results.Count site(s) available
            @if (Model.Nights > 0) { <span class="text-muted">· @Model.Nights night(s)</span> }
        </h5>

        @if (!Model.Results.Any())
        {
            <div class="alert alert-warning">No sites match those dates and filters. Try different dates or fewer filters.</div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var r in Model.Results)
                {
                    <div class="col-12 col-md-6">
                        <div class="card h-100 shadow-sm">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start">
                                    <h5 class="card-title mb-1">⛺ @r.Name</h5>
                                    @if (r.NightlyPrice.HasValue)
                                    {
                                        <span class="badge bg-success fs-6">$@r.NightlyPrice.Value.ToString("F2")/night</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Price TBD</span>
                                    }
                                </div>
                                <p class="text-muted mb-2">@r.Category</p>
                                <p class="mb-2">
                                    Max RV length:
                                    <strong>@(r.MaxRvLength == 0 ? "Not specified" : $"{r.MaxRvLength} ft")</strong>
                                </p>
                                @if (r.NightlyPrice.HasValue && Model.Nights > 0)
                                {
                                    <p class="mb-2">Estimated total: <strong>$@((r.NightlyPrice.Value * Model.Nights).ToString("F2"))</strong></p>
                                }
                                @if (isCustomer)
                                {
                                    <button class="btn btn-outline-primary btn-sm" disabled title="Booking coming soon">Reserve (coming soon)</button>
                                }
                                else
                                {
                                    <a asp-controller="CustomerAccount" asp-action="Login" class="btn btn-outline-primary btn-sm">Sign in to reserve</a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>
