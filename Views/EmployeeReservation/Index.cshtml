@model IEnumerable<Reservation>

@{
    ViewData["Title"] = "Reservation Management";
}

<div class="d-flex justify-content-between
            align-items-center mb-4">

    <div>
        <h2>Reservation Management</h2>

        <p class="text-muted mb-0">
            View, search, modify, and manage customer reservations.
        </p>
    </div>

</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<div class="card shadow-sm mb-4">

    <div class="card-body">

        <form method="get"
              asp-controller="EmployeeReservation"
              asp-action="Index">

            <div class="row g-3">

                <div class="col-md-6">

                    <label class="form-label">
                        Search
                    </label>

                    <input type="text"
                           name="search"
                           value="@ViewBag.Search"
                           class="form-control"
                           placeholder="Customer, email, phone, or site" />

                </div>

                <div class="col-md-4">

                    <label class="form-label">
                        Reservation Status
                    </label>

                    <select name="status"
                            class="form-select">

                        <option value="">
                            All Reservations
                        </option>

                        <option value="Active">
                            Active
                        </option>

                        <option value="Completed">
                            Completed
                        </option>

                        <option value="Cancelled">
                            Cancelled
                        </option>

                    </select>

                </div>

                <div class="col-md-2 d-flex align-items-end">

                    <button type="submit"
                            class="btn btn-primary w-100">

                        Search

                    </button>

                </div>

            </div>

        </form>

    </div>

</div>

<div class="card shadow-sm">

    <div class="card-body">

        <div class="table-responsive">

            <table class="table
                          table-striped
                          table-hover
                          align-middle">

                <thead>

                    <tr>
                        <th>ID</th>
                        <th>Customer</th>
                        <th>Site</th>
                        <th>Arrival</th>
                        <th>Departure</th>
                        <th>RV</th>
                        <th>Status</th>
                        <th>Total</th>
                        <th>Actions</th>
                    </tr>

                </thead>

                <tbody>

                @foreach (var reservation in Model)
                {
                    <tr>

                        <td>
                            #@reservation.Id
                        </td>

                        <td>

                            <strong>
                                @reservation.User?.Name
                            </strong>

                            <br />

                            <small class="text-muted">
                                @reservation.User?.Email
                            </small>

                        </td>

                        <td>
                            @(reservation.Site?.Name
                                ?? "Not Assigned")
                        </td>

                        <td>@reservation.StartDate.ToShortDateString()</td>

                        <td>@reservation.FinishDate.ToShortDateString()</td>

                        <td>
                            @reservation.RvLength ft
                        </td>

                        <td>

                            @if (reservation.ReservationStatus
                                 == "Cancelled")
                            {
                                <span class="badge bg-danger">
                                    Cancelled
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success">
                                    @reservation.ReservationStatus
                                </span>
                            }

                        </td>

                        <td>
                            @reservation.TotalCost.ToString("C")
                        </td>

                        <td>

                            <div class="d-flex gap-1">

                                <a asp-action="Details"
                                   asp-route-id="@reservation.Id"
                                   class="btn btn-sm
                                          btn-outline-secondary">

                                    View

                                </a>

                                @if (reservation.ReservationStatus
                                     != "Cancelled")
                                {
                                    <a asp-action="Edit"
                                       asp-route-id="@reservation.Id"
                                       class="btn btn-sm
                                              btn-outline-primary">

                                        Edit

                                    </a>

                                    <form asp-action="Cancel"
                                          asp-route-id="@reservation.Id"
                                          method="post">

                                        @Html.AntiForgeryToken()

                                        <button type="submit"
                                                class="btn btn-sm
                                                       btn-outline-danger"
                                                onclick="return confirm(
                                                'Cancel this reservation?');">

                                            Cancel

                                        </button>

                                    </form>
                                }

                            </div>

                        </td>

                    </tr>
                }

                </tbody>

            </table>

        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">

                <h5>No reservations found</h5>

                <p class="text-muted">
                    Try changing the search or status filter.
                </p>

            </div>
        }

    </div>

</div>