@model RvParkApp.Models.Employee

<h2>Edit Access Level</h2>
<hr />

<h4>Employee: <strong>@Model.Name</strong> (@Model.EmployeeId)</h4>

<form asp-action="EditAccessLevel" method="post" class="mt-4">
    <input type="hidden" name="id" value="@Model.Id" />
    
    <div style="margin-bottom: 15px;">
        <label>New Access Level (1-3):</label>
        <input type="number" name="accessLevel" value="@Model.AccessLevel" min="1" max="3" required style="width: 100px; margin-left: 10px;" />
    </div>
    
    <button type="submit" class="btn btn-success">Save Changes</button>
    <a asp-action="ManageEmployees" class="btn btn-secondary" style="margin-left: 10px;">Cancel</a>
</form>