@model List<Reservation>
@{ ViewData["Title"] = "My Reservations"; }

<h2>📋 My Reservations</h2>

@if (Model.Count == 0)
{
    <div class="alert alert-info mt-3">
        You don't have any reservations yet.
        <a asp-controller="Availability" asp-action="Search">Find an available site</a> to get started.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 g-3 mt-1">
        @foreach (var r in Model)
        {
            var nights = Math.Max(1, (r.FinishDate - r.StartDate).Days);
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="card-title mb-1">
                                @(r.Site != null ? $"⛺ {r.Site.Name}" : "⛺ Site to be assigned")
                            </h5>
                            <span class="badge @(r.ReservationStatus != null && r.ReservationStatus.StartsWith("Cancel") ? "bg-secondary" : "bg-success")">
                                @r.ReservationStatus
                            </span>
                        </div>
                        @if (r.Site?.Category != null)
                        {
                            <div class="text-muted small">@r.Site.Category.Name</div>
                        }
                        <div class="mt-2">
                            <strong>@r.StartDate.ToString("MMM d, yyyy")</strong> →
                            <strong>@r.FinishDate.ToString("MMM d, yyyy")</strong>
                            <span class="text-muted">(@nights night@(nights == 1 ? "" : "s"))</span>
                        </div>
                        <table class="table table-sm mt-2 mb-0">
                            <tbody>
                                <tr>
                                    <td>Nightly rate</td>
                                    <td class="text-end">@r.DailyRate.ToString("C")</td>
                                </tr>
                                @foreach (var rf in r.ReservationFees ?? Enumerable.Empty<ReservationFee>())
                                {
                                    <tr>
                                        <td>@(rf.Fee?.Name ?? "Fee")</td>
                                        <td class="text-end">@rf.AppliedAmount.ToString("C")</td>
                                    </tr>
                                }
                                @if (r.RefundedAmount > 0)
                                {
                                    <tr class="text-danger">
                                        <td>Refunded</td>
                                        <td class="text-end">-@r.RefundedAmount.ToString("C")</td>
                                    </tr>
                                }
                                <tr class="fw-bold border-top">
                                    <td>Total</td>
                                    <td class="text-end">@r.TotalCost.ToString("C")</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
}
