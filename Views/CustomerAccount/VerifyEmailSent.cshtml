@{
    ViewData["Title"] = "Check your email";
}

<div class="container text-center" style="max-width: 520px;">
    <h2 class="mb-3">📧 Almost there!</h2>
    <p>We've sent a verification link to your email address. Click it to activate your account, then sign in.</p>
    <p class="text-muted small">
        In development, the link is written to the application log (console) instead of being emailed.
    </p>
    <a asp-action="Login" class="btn btn-primary mt-2">Go to sign in</a>
</div>
