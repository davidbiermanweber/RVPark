@{
    ViewData["Title"] = "Set New Password";
}

<div class="container" style="max-width: 420px;">
    <h2 class="mb-3">Set a new password</h2>

    @if (ViewBag.Done == true)
    {
        <div class="alert alert-success">Your password has been reset. You can sign in now.</div>
        <a asp-action="Login" class="btn btn-success">Sign in</a>
    }
    else if (ViewBag.Invalid == true)
    {
        <div class="alert alert-danger">This reset link is invalid or has expired.</div>
        <a asp-action="ForgotPassword" class="btn btn-primary">Request a new link</a>
    }
    else
    {
        <div asp-validation-summary="All" class="text-danger"></div>
        <form method="post" asp-action="ResetPassword">
            @Html.AntiForgeryToken()
            <input type="hidden" name="token" value="@ViewBag.Token" />
            <div class="mb-3">
                <label class="form-label">New password</label>
                <input type="password" name="password" class="form-control" required minlength="8" />
            </div>
            <div class="mb-3">
                <label class="form-label">Confirm password</label>
                <input type="password" name="confirmPassword" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-primary w-100">Reset password</button>
        </form>
    }
</div>
