@{
    ViewData["Title"] = "Forgot Password";
}

<div class="container" style="max-width: 420px;">
    <h2 class="mb-3">Reset your password</h2>

    @if (ViewBag.Sent == true)
    {
        <div class="alert alert-info">
            If an account exists for that email, we've sent a reset link. (In development it's written to the app log.)
        </div>
        @if (ViewBag.DevLink is string devLink)
        {
            <div class="alert alert-warning small">
                <strong>🛠️ Development mode</strong> — no real email was sent. Reset directly:<br />
                <a href="@devLink" class="text-break">@devLink</a>
            </div>
        }
        <a asp-action="Login" class="btn btn-secondary">Back to sign in</a>
    }
    else
    {
        <form method="post" asp-action="ForgotPassword">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-primary w-100">Send reset link</button>
        </form>
    }
</div>
