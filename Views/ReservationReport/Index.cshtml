@model RvParkApp.Models.ReservationReportViewModel

@{
    ViewData["Title"] = "Reservation Report";
}

<h2 class="mb-4">Reservation Report</h2>

<form asp-action="Index" method="post" class="mb-4">
    <div class="card p-3 shadow-sm">

        <div class="row">

            <div class="col-md-4">
                <label class="form-label">Start Date</label>
                <input type="date"
                       name="startDate"
                       class="form-control"
                       required />
            </div>

            <div class="col-md-4">
                <label class="form-label">End Date</label>
                <input type="date"
                       name="endDate"
                       class="form-control"
                       required />
            </div>

            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" class="btn btn-primary">
                    Generate Report
                </button>
            </div>

        </div>

    </div>
</form>


@if (Model != null)
{
    <h3 class="mt-4">Completed Reservations</h3>

    @if (Model.Completed.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-bordered table-hover">
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Status</th>
                        <th>Start</th>
                        <th>Finish</th>
                        <th>Total Cost</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var reservation in Model.Completed)
                    {
                        <tr>
                            <td>@reservation.User?.Name</td>
                            <td>@reservation.User?.Email</td>
                            <td>@reservation.User?.Phone</td>
                            <td>@reservation.ReservationStatus</td>
                            <td>@reservation.StartDate.ToShortDateString()</td>
                            <td>@reservation.FinishDate.ToShortDateString()</td>
                            <td>@reservation.TotalCost</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">No completed reservations found.</p>
    }



    <h3 class="mt-4">Reservations In Progress</h3>

    @if (Model.InProgress.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-bordered table-hover">
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Status</th>
                        <th>Start</th>
                        <th>Finish</th>
                        <th>Total Cost</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var reservation in Model.InProgress)
                    {
                        <tr>
                            <td>@reservation.User?.Name</td>
                            <td>@reservation.User?.Email</td>
                            <td>@reservation.User?.Phone</td>
                            <td>@reservation.ReservationStatus</td>
                            <td>@reservation.StartDate.ToShortDateString()</td>
                            <td>@reservation.FinishDate.ToShortDateString()</td>
                            <td>@reservation.TotalCost</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">No reservations currently in progress.</p>
    }



    <h3 class="mt-4">Upcoming Reservations</h3>

    @if (Model.Upcoming.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-bordered table-hover">
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Status</th>
                        <th>Start</th>
                        <th>Finish</th>
                        <th>Total Cost</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var reservation in Model.Upcoming)
                    {
                        <tr>
                            <td>@reservation.User?.Name</td>
                            <td>@reservation.User?.Email</td>
                            <td>@reservation.User?.Phone</td>
                            <td>@reservation.ReservationStatus</td>
                            <td>@reservation.StartDate.ToShortDateString()</td>
                            <td>@reservation.FinishDate.ToShortDateString()</td>
                            <td>@reservation.TotalCost</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">No upcoming reservations found.</p>
    }
}

