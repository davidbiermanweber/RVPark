@model RvParkApp.Models.ReservationReportViewModel

@{
    ViewData["Title"] = "Reservation Report";
}

<h2>Reservation Report</h2>

<form asp-action="Index" method="post">
    <div>
        <label>Start Date</label>
        <input type="date" name="startDate" required />

        <label>End Date</label>
        <input type="date" name="endDate" required />

        <button type="submit">Generate Report</button>
    </div>
</form>


@if (Model != null)
{
    <h3>Completed Reservations</h3>

    <table class="table">
        <tr>
            <th>Customer</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Status</th>
            <th>Start</th>
            <th>Finish</th>
            <th>Total Cost</th>
        </tr>

        @foreach (var reservation in Model.Completed)
        {
            <tr>
                <td>@reservation.User?.Name</td>
                <td>@reservation.User?.Email</td>
                <td>@reservation.User?.Phone</td>
                <td>@reservation.ReservationStatus</td>
                <td>@reservation.StartDate.ToShortDateString()</td>
                <td>@reservation.FinishDate.ToShortDateString()</td>
                <td>@reservation.TotalCost</td>
            </tr>
        }
    </table>


    <h3>Reservations In Progress</h3>

    <table class="table">
        <tr>
            <th>Customer</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Status</th>
            <th>Start</th>
            <th>Finish</th>
        </tr>

        @foreach (var reservation in Model.InProgress)
        {
            <tr>
                <td>@reservation.User?.Name</td>
                <td>@reservation.User?.Email</td>
                <td>@reservation.User?.Phone</td>
                <td>@reservation.ReservationStatus</td>
                <td>@reservation.StartDate.ToShortDateString()</td>
                <td>@reservation.FinishDate.ToShortDateString()</td>
            </tr>
        }
    </table>


    <h3>Upcoming Reservations</h3>

    <table class="table">
        <tr>
            <th>Customer</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Status</th>
            <th>Start</th>
            <th>Finish</th>
        </tr>

        @foreach (var reservation in Model.Upcoming)
        {
            <tr>
                <td>@reservation.User?.Name</td>
                <td>@reservation.User?.Email</td>
                <td>@reservation.User?.Phone</td>
                <td>@reservation.ReservationStatus</td>
                <td>@reservation.StartDate.ToShortDateString()</td>
                <td>@reservation.FinishDate.ToShortDateString()</td>
            </tr>
        }
    </table>
}