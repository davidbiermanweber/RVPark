@model Reservation
@{
    ViewData["Title"] = "Modify Reservation Matrix";
}

<div class="container mt-4" style="max-width: 650px;">
    <div class="card shadow p-4">
        <h3 class="border-bottom pb-2 mb-4">🔧 Edit Booking #@Model.Id</h3>

        @if (ViewBag.BalanceMessage != null)
        {
            <div class="alert alert-info fw-bold">@ViewBag.BalanceMessage</div>
        }

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <!-- 💡 Fix: Explicitly declare the routing controller, action method, and reservation key ID -->
        <form method="post" asp-controller="Sites" asp-action="EditReservation" asp-route-id="@Model.Id">
            @Html.AntiForgeryToken()
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Change Arrival Date</label>
                    <input type="date" name="startDate" value="@Model.StartDate.ToString("yyyy-MM-dd")" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Change Departure Date</label>
                    <input type="date" name="finishDate" value="@Model.FinishDate.ToString("yyyy-MM-dd")" class="form-control" required />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Change Assigned Site Location</label>
                <select name="siteId" class="form-select" required>
                    @foreach (var site in ViewBag.AllSites as List<Site>)
                    {
                        <option value="@site.Id" selected="@(site.Id == Model.SiteId)">
                            @site.Name (@site.Category?.Name)
                        </option>
                    }
                </select>
            </div>

            <div class="d-flex gap-2">
                @if (Model.ReservationStatus == "Cancelled")
                {
                    <button type="submit" name="statusAction" value="UnCancel" class="btn btn-info flex-grow-1 py-2 fw-bold text-white">🔄 Activate & Un-Cancel Booking</button>
                }
                else
                {
                    <button type="submit" name="statusAction" value="Update" class="btn btn-success flex-grow-1 py-2 fw-bold">💾 Save Modifications</button>
                    <button type="submit" name="statusAction" value="Cancel" class="btn btn-danger py-2 px-4 fw-bold" onclick="return confirm('Cancel this reservation?')">❌ Cancel Booking</button>
                }
                <!-- 💡 Fix: Removed duplicate stray buttons from this section -->
            </div>
        </form>

        <div class="mt-4 text-center">
            <a asp-action="ManageReservations" class="text-decoration-none">🔙 Return to Master Desk</a>
        </div>
    </div>
</div>
