@model IEnumerable<Order>
@{
    ViewData["Title"] = "Orders";
}

<h2>Orders</h2>

<table class="table">
    <thead>
        <tr>
            <th>#</th>
            <th>Customer</th>
            <th>Site</th>
            <th>Check-In</th>
            <th>Check-Out</th>
            <th>Amount</th>
            <th>Status</th>
            <th>Created</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.Id</td>
                <td>@(order.Customer?.Name ?? order.CustomerId.ToString())</td>
                <td>@(order.Site?.Name ?? order.SiteId.ToString())</td>
                <td>@order.CheckIn.ToString("MM/dd/yyyy")</td>
                <td>@order.CheckOut.ToString("MM/dd/yyyy")</td>
                <td>$@order.Amount.ToString("F2")</td>
                <td>@order.Status</td>
                <td>@order.CreatedAt.ToString("MM/dd/yyyy")</td>
            </tr>
            <td>
                @if (order.Status != "Cancelled")
                {
                    <form asp-action="Cancel" asp-route-id="@order.Id" method="post"
                          onsubmit="return confirm('Cancel this order?');">
                        <button type="submit" class="btn btn-danger btn-sm">Cancel</button>
                    </form>
                }
            </td>

        }
    </tbody>
</table>
